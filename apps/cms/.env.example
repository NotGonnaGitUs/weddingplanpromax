# apps/cms — Payload marketplace
# Local default: SQLite file DB (no Mongo required)
DATABASE_URI=file:./data/marrymap.db
# Or MongoDB:
# DATABASE_URI=mongodb://127.0.0.1/marrymap

PAYLOAD_SECRET=replace-me-with-a-long-random-string
PORT=3000

# Set to 1 to skip auto-seed on boot
# SKIP_SEED=1

# Stripe (marketplace / Connect)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Platform commission on confirmed bookings (0.10 = 10%)
PLATFORM_FEE_RATE=0.10
